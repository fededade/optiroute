# ============================================
# OptiRoute - Variabili d'ambiente
# ============================================

# --- Frontend (Vite: prefisso VITE_, visibili nel browser) ---

# Webhook n8n per l'invio del report Excel (opzionale, ha un default nel codice)
VITE_N8N_WEBHOOK_URL=

# Chiave Gemini per la pulizia AI degli indirizzi in inserimento rapido (opzionale:
# senza chiave l'indirizzo viene usato così com'è)
VITE_GEMINI_API_KEY=

# --- Backend / Vercel Serverless (mai esposte al browser) ---

# Google Maps Directions (già usata da api/directions.ts)
GOOGLE_MAPS_API_KEY=

# Retell AI - chiamata di conferma appuntamento (api/retell-call.ts)
# API key dalla dashboard Retell (https://dashboard.retellai.com -> API Keys)
RETELL_API_KEY=

# Numero telefonico in uscita acquistato/importato su Retell, formato E.164 (es. +39...)
RETELL_FROM_NUMBER=

# (Opzionale) ID dell'agente Retell da usare per la chiamata; se omesso viene
# usato l'agente in uscita associato al numero
RETELL_AGENT_ID=

# (Opzionale) Nome dell'azienda pronunciato dall'operatore AI
RETELL_COMPANY_NAME=
